{
  "title": "Host Overview",
  "uid": "host-overview",
  "version": 1,
  "schemaVersion": 38,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1, "type": "gauge", "title": "CPU Usage %",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 6 },
      "targets": [{
        "datasource": "Prometheus",
        "expr": "100 - (avg(rate(node_cpu_seconds_total{mode='idle'}[5m])) * 100)",
        "legendFormat": "CPU %"
      }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": {
        "defaults": {
          "min": 0, "max": 100, "unit": "percent",
          "thresholds": {
            "steps": [
              { "color": "green",  "value": 0  },
              { "color": "yellow", "value": 70 },
              { "color": "red",    "value": 90 }
            ]
          }
        }
      }
    },
    {
      "id": 2, "type": "gauge", "title": "Memory Usage %",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 6 },
      "targets": [{
        "datasource": "Prometheus",
        "expr": "(1 - (node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes)) * 100",
        "legendFormat": "Memory %"
      }],
      "fieldConfig": {
        "defaults": {
          "min": 0, "max": 100, "unit": "percent",
          "thresholds": {
            "steps": [
              { "color": "green",  "value": 0  },
              { "color": "yellow", "value": 75 },
              { "color": "red",    "value": 90 }
            ]
          }
        }
      }
    },
    {
      "id": 3, "type": "gauge", "title": "Disk Usage % (/)",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 6 },
      "targets": [{
        "datasource": "Prometheus",
        "expr": "(1 - node_filesystem_avail_bytes{mountpoint='/'} / node_filesystem_size_bytes{mountpoint='/'}) * 100",
        "legendFormat": "Disk %"
      }],
      "fieldConfig": {
        "defaults": {
          "min": 0, "max": 100, "unit": "percent",
          "thresholds": {
            "steps": [
              { "color": "green",  "value": 0  },
              { "color": "yellow", "value": 75 },
              { "color": "red",    "value": 90 }
            ]
          }
        }
      }
    },
    {
      "id": 4, "type": "stat", "title": "System Uptime",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 6 },
      "targets": [{
        "datasource": "Prometheus",
        "expr": "node_time_seconds - node_boot_time_seconds"
      }],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "id": 5, "type": "timeseries", "title": "CPU Usage over time",
      "gridPos": { "x": 0, "y": 6, "w": 12, "h": 8 },
      "targets": [{
        "datasource": "Prometheus",
        "expr": "100 - (avg by(cpu) (rate(node_cpu_seconds_total{mode='idle'}[5m])) * 100)",
        "legendFormat": "Core {{cpu}}"
      }],
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100 } }
    },
    {
      "id": 6, "type": "timeseries", "title": "Memory Breakdown",
      "gridPos": { "x": 12, "y": 6, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "node_memory_MemTotal_bytes - node_memory_MemFree_bytes - node_memory_Buffers_bytes - node_memory_Cached_bytes",
          "legendFormat": "Used"
        },
        {
          "datasource": "Prometheus",
          "expr": "node_memory_Buffers_bytes + node_memory_Cached_bytes",
          "legendFormat": "Buffers/Cache"
        },
        {
          "datasource": "Prometheus",
          "expr": "node_memory_MemFree_bytes",
          "legendFormat": "Free"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes" } }
    },
    {
      "id": 7, "type": "timeseries", "title": "Network I/O",
      "gridPos": { "x": 0, "y": 14, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "rate(node_network_receive_bytes_total{device!='lo'}[5m])",
          "legendFormat": "RX {{device}}"
        },
        {
          "datasource": "Prometheus",
          "expr": "rate(node_network_transmit_bytes_total{device!='lo'}[5m])",
          "legendFormat": "TX {{device}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "Bps" } }
    },
    {
      "id": 8, "type": "timeseries", "title": "Disk I/O",
      "gridPos": { "x": 12, "y": 14, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "rate(node_disk_read_bytes_total[5m])",
          "legendFormat": "Read {{device}}"
        },
        {
          "datasource": "Prometheus",
          "expr": "rate(node_disk_written_bytes_total[5m])",
          "legendFormat": "Write {{device}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "Bps" } }
    }
  ]
}
